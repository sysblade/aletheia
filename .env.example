# Storage backend: sqlite | mongodb | clickhouse
STORE_TYPE=sqlite

# SQLite
DB_PATH=./data/aletheia.sqlite
DB_RETENTION_DAYS=90
DB_MAINTENANCE_INTERVAL_HOURS=6

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DATABASE=aletheia
MONGO_SOCKET_TIMEOUT_MS=15000
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2
MONGO_MAX_IDLE_TIME_MS=300000

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=aletheia
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_REQUEST_TIMEOUT_MS=30000

# CertStream
CERTSTREAM_URL=wss://api.certstream.dev/

# Ingestor
BATCH_SIZE=500
BATCH_INTERVAL=3000
BATCH_MAX_QUEUE_SIZE=50

# Filters (comma-separated)
FILTER_DOMAINS=
FILTER_ISSUERS=

# Server
PORT=3000
HOST=0.0.0.0

# Stats
STATS_ENABLED=true
STATS_HOURLY_SCHEDULE=5 * * * *
STATS_DAILY_SCHEDULE=5 0 * * *

# Logging
LOG_LEVEL=info
