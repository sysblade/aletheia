DB_PATH=./data/ctlog.sqlite
DB_RETENTION_DAYS=90
CERTSTREAM_URL=wss://certstream.calidog.io
BATCH_SIZE=500
BATCH_INTERVAL=3000
PORT=3000
HOST=0.0.0.0

# Filters (comma-separated). Only certs matching at least one filter are stored.
# Empty = store everything (firehose mode).
# Supports glob patterns: *.example.com, *bank*, gov.*
FILTER_DOMAINS=
# Filter by issuer organization (exact substring match, comma-separated)
FILTER_ISSUERS=
