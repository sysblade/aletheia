# -- Storage ----------------------------------------------------------
# Which database backend to use: "sqlite" (default) or "mongodb"
STORE_TYPE=sqlite

# -- SQLite ------------------------------------------------------------
DB_PATH=./data/ctlog.sqlite
DB_RETENTION_DAYS=90

# -- MongoDB -----------------------------------------------------------
MONGO_URL=mongodb://localhost:27017
MONGO_DATABASE=ctlog

# -- CertStream --------------------------------------------------------
CERTSTREAM_URL=wss://api.certstream.dev/

# -- Batch Buffer ------------------------------------------------------
# Flush when buffer reaches this many certificates
BATCH_SIZE=500
# Flush every N milliseconds regardless of buffer size
BATCH_INTERVAL=3000

# -- Server ------------------------------------------------------------
PORT=3000
HOST=0.0.0.0

# -- Filters -----------------------------------------------------------
# Comma-separated domain glob patterns (e.g., "*.google.com,*.github.com")
# Leave empty for firehose mode (all certificates)
FILTER_DOMAINS=
# Comma-separated issuer substrings (e.g., "Lets Encrypt,DigiCert")
FILTER_ISSUERS=

# -- Logging -----------------------------------------------------------
# trace | debug | info | warning | error | fatal
LOG_LEVEL=info
