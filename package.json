{
  "name": "ctlog",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts serve",
    "start": "bun run src/index.ts serve",
    "check": "bun x tsc --noEmit",
