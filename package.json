    "compile": "bun build src/index.ts --compile --outfile out/ctlog",
    "clean": "rm -rf out/"
  },
  "dependencies": {
    "@logtape/logtape": "^0.12.0",
    "commander": "^12.1.0",
    "croner": "^10.0.1",
    "hono": "^4.7.0",
    "kysely": "^0.27.0",
    "kysely-bun-sqlite": "^0.3.0",
    "mongodb": "^6.12.0",
    "p-queue": "^9.1.0",
    "psl": "^1.15.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
