{
  "name": "Aletheia",
  "image": "oven/bun:1.3.3",

  "workspaceFolder": "/workspaces/aletheia",

  // Install deps after container creation
  "postCreateCommand": "bun install",

  "remoteUser": "bun",

  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Aletheia Web",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        // Bun runtime support (run/debug bun scripts, test runner UI)
        "oven.bun-vscode",
        // TypeScript language server
        "ms-vscode.vscode-typescript-next",
        // Inline error display
        "usernamehw.errorlens",
        // SQLite viewer for inspecting the dev DB
        "qwtel.sqlite-viewer"
      ],
      "settings": {
        "typescript.tsdk": "node_modules/typescript/lib",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-vscode.vscode-typescript-next"
      }
    }
  },

  "containerEnv": {
    "STORE_TYPE": "sqlite",
    "DB_PATH": "/workspaces/aletheia/data/aletheia.sqlite",
    "HOST": "0.0.0.0",
    "PORT": "3000",
    "LOG_LEVEL": "debug"
  }
}
